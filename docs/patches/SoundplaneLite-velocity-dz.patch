From 24e9c0a119ea65b56c5effa476d936c45d2c68e7 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Mon, 6 Jul 2026 05:06:44 +0000
Subject: [PATCH] expose touch dz + tracker tuning through SPLiteDevice API

- SPLiteCallback: add touchOn/touchContinue/touchOff overloads carrying the
  touch tracker's dz (per-frame pressure delta), default-forwarding to the
  existing 3-float variants so current callbacks keep working. dz at the
  touch-on frame captures the pre-threshold pressure rise, giving clients a
  zero-latency note-on velocity source.
- SPLiteDevice: add touchThreshold()/lopassZ() setters so clients can tune
  the touch tracker instead of the previously hardcoded 0.05/100.0.
- fix missing standard includes (cstdint/iosfwd/stdio/stdexcept) that break
  the build on newer gcc.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
Claude-Session: https://claude.ai/code/session_0126wAgmFViCARDgCuVCTaR1
---
 splite/SPLiteDevice.cpp                 | 22 +++++++++++++++++-----
 splite/SPLiteDevice.h                   | 11 +++++++++++
 splite/splib/LibusbSoundplaneDriver.cpp |  1 +
 splite/splib/SensorFrame.h              |  1 +
 splite/splib/SoundplaneModelA.cpp       |  1 +
 splite/splib/SoundplaneModelA.h         |  1 +
 6 files changed, 32 insertions(+), 5 deletions(-)

diff --git a/splite/SPLiteDevice.cpp b/splite/SPLiteDevice.cpp
index 9b7d04f..25bc4c5 100644
--- a/splite/SPLiteDevice.cpp
+++ b/splite/SPLiteDevice.cpp
@@ -64,6 +64,8 @@ public:
     void addCallback(std::shared_ptr<SPLiteCallback> cb) {     callbacks_.push_back(cb);}
     void maxTouches(unsigned t) { maxTouches_ = t;  }
     void overrideCarrierSet(int c);
+    void touchThreshold(float t) { touchThreshold_ = t; }
+    void lopassZ(float f) { lopassZ_ = f; }
 
     void onStartup(void);
     void onFrame(const SensorFrame &frame);
@@ -95,6 +97,8 @@ private:
     bool isCal_ = false;
     bool isCarrierSet_ = false;
     int  overrideCarrier_ = -1;
+    float touchThreshold_ = 0.05f;
+    float lopassZ_ = 100.0f;
     SoundplaneDriver::Carriers carriers_;
     SensorFrameStats stats_;
     SensorFrame calibrateMeanInv_{};
@@ -133,8 +137,8 @@ void SPLiteImpl_::onStartup(void) {
     isCal_ = false;
 
     tracker_.setRotate(false);
-    tracker_.setThresh(0.05f);
-    tracker_.setLopassZ(100.0f);
+    tracker_.setThresh(touchThreshold_);
+    tracker_.setLopassZ(lopassZ_);
 }
 
 void SPLiteImpl_::onFrame(const SensorFrame &frame) {
@@ -244,19 +248,19 @@ void SPLiteImpl_::onTouches(TouchArray &ta) {
         switch (t.state) {
             case kTouchStateOn : {
                 for (auto cb : callbacks_) {
-                    cb->touchOn(idx, t.x, t.y, t.z);
+                    cb->touchOn(idx, t.x, t.y, t.z, t.dz);
                 }
                 break;
             };
             case kTouchStateContinue : {
                 for (auto cb : callbacks_) {
-                    cb->touchContinue(idx, t.x, t.y, t.z);
+                    cb->touchContinue(idx, t.x, t.y, t.z, t.dz);
                 }
                 break;
             };
             case kTouchStateOff : {
                 for (auto cb : callbacks_) {
-                    cb->touchOff(idx, t.x, t.y, t.z);
+                    cb->touchOff(idx, t.x, t.y, t.z, t.dz);
                 }
                 break;
             };
@@ -304,6 +308,14 @@ void SPLiteDevice::overrideCarrierSet(int c) {
     impl_->overrideCarrierSet(c);
 }
 
+void SPLiteDevice::touchThreshold(float t) {
+    impl_->touchThreshold(t);
+}
+
+void SPLiteDevice::lopassZ(float f) {
+    impl_->lopassZ(f);
+}
+
 void SPLiteDevice::addCallback(std::shared_ptr<SPLiteCallback> cb) {
     impl_->addCallback(cb);
 }
diff --git a/splite/SPLiteDevice.h b/splite/SPLiteDevice.h
index 6d76c81..f3e9fdf 100644
--- a/splite/SPLiteDevice.h
+++ b/splite/SPLiteDevice.h
@@ -14,6 +14,14 @@ public:
     virtual void touchOn(unsigned voice, float x,float y, float z) = 0;
     virtual void touchContinue(unsigned voice, float x,float y, float z) = 0;
     virtual void touchOff(unsigned voice, float x,float y, float z) = 0;
+
+    // dz = change in pressure since previous frame, as reported by the touch
+    // tracker; available from the touch-on frame (captures the pre-threshold
+    // pressure rise). Default implementations forward to the 3-float variants
+    // so existing callbacks keep working.
+    virtual void touchOn(unsigned voice, float x,float y, float z, float dz) { touchOn(voice, x, y, z); }
+    virtual void touchContinue(unsigned voice, float x,float y, float z, float dz) { touchContinue(voice, x, y, z); }
+    virtual void touchOff(unsigned voice, float x,float y, float z, float dz) { touchOff(voice, x, y, z); }
 };
 
 class SPLiteImpl_;
@@ -28,6 +36,9 @@ public:
     void addCallback(std::shared_ptr<SPLiteCallback>);
     void maxTouches(unsigned);
     void overrideCarrierSet(int carrier);
+    // touch tracker tuning, take effect when the device (re)starts
+    void touchThreshold(float thresh);  // curvature that causes a touch, default 0.05
+    void lopassZ(float freq);           // z lowpass base frequency in Hz, default 100
 private:
     SPLiteImpl_* impl_;
 };
